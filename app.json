{
  "expo": {
    "name": "Pocket Bash Kids",
    "slug": "pocket-bash-kids",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-bg.png",
      "resizeMode": "cover",
      "backgroundColor": "#1A1A1A"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png",
      "baseUrl": "/app"
    },
    "platforms": ["ios", "android", "web"],
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.discoverpretoriaeast.pocketbashkids",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A1A1A"
      },
      "package": "com.discoverpretoriaeast.pocketbashkids",
      "versionCode": 1
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-font",
      "expo-updates"
    ],
    "updates": {
      "url": "https://u.expo.dev/pocket-bash-kids",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "scheme": "pocketbashkids",
    "owner": "discover_pretoria_east",
    "extra": {
      "eas": {
        "projectId": "pocket-bash-kids"
      }
    }
  }
}
