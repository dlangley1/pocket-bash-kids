{
  "expo": {
    "name": "Pocket Bash Kids",
    "slug": "pocket-bash-kids",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A1A1A"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.discoverpretoriaeast.pocketbashkids",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A1A1A"
      },
      "package": "com.discoverpretoriaeast.pocketbashkids",
      "versionCode": 1
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-font"
    ],
    "scheme": "pocketbashkids",
    "owner": "discover_pretoria_east",
    "extra": {
      "eas": {
        "projectId": "pocket-bash-kids"
      }
    }
  }
}
